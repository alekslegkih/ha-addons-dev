#!/usr/bin/with-contenv bashio
# shellcheck shell=bash
set -euo pipefail

bashio::log "============================================="
bashio::log.green " Запуск инициализации Caddy Proxy"
bashio::log "============================================="

# -----------------------------------------------------------------------------
# ПУТИ
# -----------------------------------------------------------------------------
CONFIG_BASE="/config/caddy_proxy"
SITES_DIR="${CONFIG_BASE}/sites"
META_DIR="${CONFIG_BASE}/meta"
DATA_CADDYFILE="/data/Caddyfile"

# -----------------------------------------------------------------------------
# 1. ЧТЕНИЕ ОПЦИЙ
# -----------------------------------------------------------------------------
bashio::log "Шаг 1: Чтение конфигурации..."

LOG_LEVEL=$(bashio::config 'log_level')
bashio::log "   Уровень логов Caddy: ${LOG_LEVEL}"

# -----------------------------------------------------------------------------
# 2. СОЗДАНИЕ СТРУКТУРЫ ПАПОК
# -----------------------------------------------------------------------------
bashio::log "Шаг 2: Создание структуры папок..."

if ! mkdir -p "${SITES_DIR}" 2>/dev/null; then
    bashio::log.red "   Ошибка: не удалось создать ${SITES_DIR}"
    exit 1
fi

if ! mkdir -p "${META_DIR}" 2>/dev/null; then
    bashio::log.red "   Ошибка: не удалось создать ${META_DIR}"
    exit 1
fi

bashio::log.green "   Папки созданы:"
bashio::log.green "     - ${SITES_DIR}"
bashio::log.green "     - ${META_DIR}"

# -----------------------------------------------------------------------------
# 3. СОЗДАНИЕ ГЛАВНОГО CADDYFILE (всегда перезаписывается)
# -----------------------------------------------------------------------------
bashio::log "Шаг 3: Создание главного Caddyfile..."

if ! cat > "${DATA_CADDYFILE}" <<EOF
# ================================================================
# ГЛАВНЫЙ КОНФИГ CADDY
# Сгенерирован аддоном caddy_proxy $(date)
# НЕ РЕДАКТИРОВАТЬ
# ================================================================

# Глобальные настройки логирования (из options.json)
{
    log {
        level ${LOG_LEVEL}
        output file /var/log/caddy/access.log {
            roll_size 10MB
            roll_keep 5
        }
    }
}

# Импорт всех конфигов сайтов
import ${SITES_DIR}/*.caddy
EOF
then
    bashio::log.red "   Ошибка: не удалось создать ${DATA_CADDYFILE}"
    exit 1
fi

bashio::log.green "   Создан: ${DATA_CADDYFILE}"
bashio::log "Уровень логирования: ${LOG_LEVEL})"

# -----------------------------------------------------------------------------
# 4. ЗАВЕРШЕНИЕ
# -----------------------------------------------------------------------------
bashio::log "============================================="
bashio::log.green " Инициализация завершена"
bashio::log "============================================="

exit 0
