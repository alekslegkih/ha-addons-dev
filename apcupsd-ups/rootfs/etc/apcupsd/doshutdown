#!/usr/bin/with-contenv bashio
# shellcheck shell=bash

set -e

# Подгружаем runtime параметры
# shellcheck disable=SC1091
source /run/apcupsd/options.env

bashio::log.yellow "UPS requested system shutdown"

if [ "${SHUTDOWN_HOST}" = "true" ]; then
    bashio::log.yellow "Shutting down host via Supervisor"

#    curl -s \
#        -H "Authorization: Bearer ${SUPERVISOR_TOKEN}" \
#        http://supervisor/host/shutdown

    # Блокируем дефолтный shutdown apcupsd
    exit 99
fi

# Если shutdown_host=false → ничего не делаем
exit 0
