#!/usr/bin/with-contenv bashio
# shellcheck shell=bash

set -euo pipefail

# ------------------------------------------------------------------
# Static paths
# ------------------------------------------------------------------

DIR_ADDON="nc_user_files_backup"  # addon home path
BASE_DIR="/usr/local/${DIR_ADDON}"
export BASE_DIR

CONFIG_DIR="/config"
DEBUG_FLAG="${CONFIG_DIR}/debug.flag"

RUNTIME_DIR="/run/${DIR_ADDON}"

# ------------------------------------------------------------------
# Start
# ------------------------------------------------------------------

ADDON_VERSION="$(bashio::addon.version)"
ADDON_NAME=$(bashio::addon.name)

bashio::log "========================================"
bashio::log.green "=== ${ADDON_NAME} ==="
bashio::log.green "=== Version:  ${ADDON_VERSION} ==="
bashio::log.green "Starting at: $(date '+%Y-%m-%d %H:%M:%S')"
bashio::log "========================================"

# ------------------------------------------------------------------
# logger for addon
# User-friendly by default, debug via /config/debug.flag
# ------------------------------------------------------------------

log_debug() {
    if [ -n "${DEBUG_FLAG:-}" ] && [ -f "${DEBUG_FLAG}" ]; then
        bashio::log.magenta "[DEBUG] $*"
    fi
}

log_debug "Script started"
log_debug "BASE_DIR=${BASE_DIR}"

# ------------------------------------------------------------------
# Load modules
# ------------------------------------------------------------------

log_debug "Loading modules..."

source "${BASE_DIR}/core/config.sh"

log_debug "Modules ${BASE_DIR} loaded"

# ------------------------------------------------------------------
# Helpers
# ------------------------------------------------------------------

emit() {
    log_debug "Emit called with args: $*"
    python3 "${BASE_DIR}/ha/emit_cli.py" "$@" || {
        log_debug "Emit failed (ignored)"
        true
    }
}

# ------------------------------------------------------------------
# Runtime ENV writer
# ------------------------------------------------------------------

write_runtime_env() {

    local ENV_FILE="${RUNTIME_DIR}/runtime.env"
    local TMP_FILE="${ENV_FILE}.tmp"

    log_debug "Preparing runtime env directory: ${RUNTIME_DIR}"
    mkdir -p "${RUNTIME_DIR}"

    log_debug "Writing runtime env to temp file: ${TMP_FILE}"
    : > "${TMP_FILE}"

    printf 'SCHEDULE=%q\n' "$SCHEDULE" >> "$TMP_FILE"
    printf 'RSYNC_OPTIONS=%q\n' "$RSYNC_OPTIONS" >> "$TMP_FILE"
    printf 'TIMEZONE=%q\n' "$TIMEZONE" >> "$TMP_FILE"
    printf 'TEST_MODE=%q\n' "$TEST_MODE" >> "$TMP_FILE"

    printf 'SOURCE_DEVICE=%q\n' "$SOURCE_DEVICE" >> "$TMP_FILE"
    printf 'SOURCE_DIR=%q\n' "$SOURCE_DIR" >> "$TMP_FILE"

    printf 'DEST_DEVICE=%q\n' "$DEST_DEVICE" >> "$TMP_FILE"
    printf 'DEST_DIR=%q\n' "$DEST_DIR" >> "$TMP_FILE"

    printf 'SOURCE_PATH=%q\n' "$SOURCE_PATH" >> "$TMP_FILE"
    printf 'DEST_PATH=%q\n' "$DEST_PATH" >> "$TMP_FILE"

    printf 'POWER_ENABLED=%q\n' "$POWER_ENABLED" >> "$TMP_FILE"
    printf 'DISK_SWITCH=%q\n' "$DISK_SWITCH" >> "$TMP_FILE"

    printf 'CONFIG_DIR=%q\n' "$CONFIG_DIR" >> "$TMP_FILE"
    printf 'TARGET_ROOT=%q\n' "$TARGET_ROOT" >> "$TMP_FILE"
    printf 'DEBUG_FLAG=%q\n' "$DEBUG_FLAG" >> "$TMP_FILE"

    chmod 600 "$TMP_FILE"
    mv "$TMP_FILE" "$ENV_FILE"

    log_debug "Runtime env written to ${ENV_FILE}"

}



# ------------------------------------------------------------------
# Cron job create
# ------------------------------------------------------------------

install_cron_job() {

    local CRON_FILE="/etc/crontabs/root"
    local TRIGGER="${RUNTIME_DIR}/trigger_backup"

    log_debug "install_cron_job(): start"
    log_debug "Schedule value: ${SCHEDULE}"

    bashio::log "Installing cron job"

    log_debug "Ensuring cron directory exists: /etc/crontabs"
    mkdir -p /etc/crontabs || {
        bashio::log.red "Failed to create /etc/crontabs directory"
        return 1
    }

    log_debug "Writing cron file: ${CRON_FILE}"

    cat > "${CRON_FILE}" <<EOF
SHELL=/bin/sh
PATH=/usr/sbin:/usr/bin:/sbin:/bin

${SCHEDULE} touch ${TRIGGER}
EOF

    log_debug "Cron file content:"
    log_debug "$(cat ${CRON_FILE})"

    chmod 600 "${CRON_FILE}" || {
        bashio::log.red "Failed to set permissions on ${CRON_FILE}"
        return 1
    }

    log_debug "Permissions set on ${CRON_FILE}"

    bashio::log.green "Cron job installed successfully"
    log_debug "install_cron_job(): completed"
}

# ------------------------------------------------------------------
# Main (configuration phase only)
# ------------------------------------------------------------------

log_debug "Emitting addon_started event"
emit service_state '{"reason":"addon_started"}'

bashio::log.blue "=== Configuration ==="
log_debug "Starting configuration phase"

set +e 
load_config 
rc=$? 
set -e 

if [ "$rc" -ne 0 ]; then 
    bashio::log.red "Configuration load failed" 
    if [ -f /run/s6-linux-init-container-results/exitcode ]; 
        then echo 0 > /run/s6-linux-init-container-results/exitcode 
    fi 
        
    bashio::log.red "Service crashed (exit code: $rc) —configuration error" 
    exec /run/s6/basedir/bin/halt
fi

# Cron load
install_cron_job

bashio::log.green "Configuration loaded"

log_debug "Configuration loaded successfully"
log_debug "SOURCE_DEVICE=${SOURCE_DEVICE}"
log_debug "SOURCE_DIR=${SOURCE_DIR}"
log_debug "DEST_DEVICE=${DEST_DEVICE}"
log_debug "DEST_DIR=${DEST_DIR}"
log_debug "SOURCE_PATH=${SOURCE_PATH}"
log_debug "DEST_PATH=${DEST_PATH}"
log_debug "SCHEDULE=${SCHEDULE}"
log_debug "RSYNC_OPTIONS=${RSYNC_OPTIONS}"
log_debug "TIMEZONE=${TIMEZONE}"
log_debug "TEST_MODE=${TEST_MODE}"
log_debug "POWER_ENABLED=${POWER_ENABLED}"
log_debug "DISK_SWITCH=${DISK_SWITCH}"
log_debug "CONFIG_DIR=${CONFIG_DIR}"
log_debug "TARGET_ROOT=${TARGET_ROOT}"
log_debug "DEBUG_FLAG=${DEBUG_FLAG:-not_set}"

write_runtime_env

log_debug "Configuration phase completed"
log_debug "Script exiting successfully"

# ------------------------------------------------------------------
# Flag barier
# ------------------------------------------------------------------
touch "${RUNTIME_DIR}/service.ready"

exit 0